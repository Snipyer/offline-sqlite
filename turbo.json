{
	"$schema": "https://turbo.build/schema.json",
	"ui": "stream",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"dev:public": {
			"cache": false,
			"persistent": true
		},
		"dev:admin": {
			"cache": false,
			"persistent": true
		},
		"db:push": {
			"cache": false
		},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false,
			"persistent": true
		},
		"db:studio": {
			"cache": false,
			"persistent": true
		},
		"desktop:dev": {
			"cache": false,
			"persistent": true
		},
		"desktop:build": {
			"cache": false
		},
		"desktop:build:win": {
			"cache": false
		},
		"cf:dev": {
			"cache": false,
			"persistent": true
		},
		"cf:dev:public": {
			"cache": false,
			"persistent": true
		},
		"cf:dev:admin": {
			"cache": false,
			"persistent": true
		}
	}
}
